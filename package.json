{
  "name": "librarr",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "nodemon",
    "build:server": "tsc --project server/tsconfig.json",
    "build:next": "next build",
    "build": "npm run build:server && npm run build:next",
    "start": "NODE_ENV=production node dist/server/index.js",
    "lint": "eslint .",
    "migration:generate": "typeorm migration:generate -d server/datasource.ts",
    "migration:run": "typeorm migration:run -d server/datasource.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui-host 0.0.0.0",
    "test:e2e:report": "monocart show-report .reports/monocart/index.html",
    "test:coverage:report": "npx serve .reports/coverage"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "connect-typeorm": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "node-cache": "^5.1.2",
    "node-schedule": "^2.1.1",
    "nodemailer": "^8.0.1",
    "openid-client": "^6.8.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "swr": "^2.4.0",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.5.0",
    "@types/node-schedule": "^2.1.8",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "monocart-reporter": "^2.10.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
